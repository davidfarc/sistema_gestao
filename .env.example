# ─────────────────────────────────────────────────────────────────────────────
# Copie para apps/web/.env.local e preencha. NUNCA commitar o .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — projeto na região South America (São Paulo)
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# Publishable key (novo formato sb_publishable_...; segura p/ cliente = antiga anon).
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# SECRET key (novo formato sb_secret_... = antiga service_role). Só no servidor,
# jamais no bundle do cliente (sem NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Domínio interno: e-mails deste domínio = usuários internos (acesso total ao board).
# Externos entram por Google mas só veem cards atribuídos a eles.
INTERNAL_EMAIL_DOMAIN="editoraeccoprime.com.br"

# Google OAuth (configurado dentro do Supabase Auth > Providers > Google).
# O Client ID/Secret ficam no painel do Supabase; aqui só para referência local se precisar.
# GOOGLE_OAUTH_CLIENT_ID=""
# GOOGLE_OAUTH_CLIENT_SECRET=""
